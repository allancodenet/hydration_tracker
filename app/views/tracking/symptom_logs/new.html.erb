<%= turbo_frame_tag "tracking_form" do %>
  <nav aria-label="Progress">
    <ol role="list" class="space-y-4 md:flex md:space-y-0 md:space-x-8">
      <li class="md:flex-1">
        <!-- Completed Step -->
        <a href="#" class="group flex flex-col border-l-4 border-indigo-600 py-2 pl-4 hover:border-indigo-800 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-800">Step 1</span>
          <span class="text-sm font-medium">Beverage Information</span>
        </a>
      </li>

      <li class="md:flex-1">
        <!-- Completed Step -->
        <a href="#" class="group flex flex-col border-l-4 border-indigo-600 py-2 pl-4 hover:border-indigo-800 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-800">Step 2</span>
          <span class="text-sm font-medium">Symptom Information</span>
        </a>
      </li>

      <%# <li class="md:flex-1">
        <!-- Current Step -->
        <a href="#" class="group flex flex-col border-l-4 border-indigo-600 py-2 pl-4 hover:border-indigo-800 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-800">Step 3</span>
          <span class="text-sm font-medium">Preferences</span>
        </a>
      </li> %>
    </ol>
  </nav>

  <div class="bg-gray-100 py-8 px-4 shadow sm:rounded-lg sm:px-10 mt-10">
    <%= form_with model: @symptom_log, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :symptom_id, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :symptom_id, Symptom.all.map { |symptom| [symptom.name, symptom.id] }, {prompt: "Select a symptom"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :symptom_severity, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :symptom_severity, Tracker::SYMPTOM_SEVERITY, {prompt: "Select a severity"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
      <div>
        <%= f.label :symptom_timing, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :symptom_timing, Tracker::SYMPTOM_TIMING, {prompt: "Select a timing"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Finish", data: { turbo_frame: "_top" }, class: "flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      </div>

      <% if @symptom_log.errors.any? %>
        <p class="mt-2 text-sm text-red-600">
          <%= @symptom_log.errors.full_messages.join(", ") %>
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>