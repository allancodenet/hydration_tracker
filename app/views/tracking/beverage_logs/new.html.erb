<%= turbo_frame_tag "tracking_form" do %>
  <nav aria-label="Progress">
    <ol role="list" class="space-y-4 md:flex md:space-y-0 md:space-x-8">
      <li class="md:flex-1">
        <!-- Completed Step -->
        <a href="#" class="group flex flex-col border-l-4 border-indigo-600 py-2 pl-4 hover:border-indigo-800 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-800">Step 1</span>
          <span class="text-sm font-medium">Beverage Information</span>
        </a>
      </li>

      <li class="md:flex-1">
        <!-- Upcoming Step -->
        <a href="#" class="group flex flex-col border-l-4 border-gray-200 py-2 pl-4 hover:border-gray-300 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-gray-500 group-hover:text-gray-700">Step 2</span>
          <span class="text-sm font-medium">Symptom Information</span>
        </a>
      </li>
<%# 
      <li class="md:flex-1">
        <!-- Upcoming Step -->
        <a href="#" class="group flex flex-col border-l-4 border-gray-200 py-2 pl-4 hover:border-gray-300 md:border-l-0 md:border-t-4 md:pl-0 md:pt-4 md:pb-0">
          <span class="text-sm font-medium text-gray-500 group-hover:text-gray-700">Step 3</span>
          <span class="text-sm font-medium">Preferences</span>
        </a>
      </li> %>
    </ol>
  </nav>

  <div class="bg-gray-100 py-8 px-4 shadow sm:rounded-lg sm:px-10 mt-10">
    <%= form_with model: @beverage_log, class: "space-y-6", data: {controller: "beverage-category-select"} do |f| %>
      <div>
        <%= f.label :beverage_category_id, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :beverage_id, BeverageCategory.all.map { |beverage_category| [beverage_category.name, beverage_category.id] }, {},  
          data: { beverage_category_select_target: "category", action: "beverage-category-select#updateSubcategories", beverage_category_select_url_param: api_beverages_path}, 
          class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
      <div>
        <%= f.label :beverage_id, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :beverage_id, Beverage.all.map { |beverage| [beverage.name, beverage.id] }, {}, data: { beverage_category_select_target: "subCategory"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
      <div>
        <%= f.label :additive_id, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.select :additive_id, Additive.all.map { |additive| [additive.name, additive.id] }, {prompt: "Select an additive"}, data: { beverage_category_select_target: "subCategory"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
      <span class="text-sm font-medium text-gray-700">Quantity fields</span>
      <div>
        <%= f.fields_for :quantity do |quantity_fields| %>
          <%= quantity_fields.label :value, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= quantity_fields.text_field :value, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <%= quantity_fields.label :unit_type, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= quantity_fields.select :unit_type, Quantity::ALL_UNITS, {prompt: "Select a unit"}, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
          </div>
        <% end %>
      </div>
      <span class="text-sm font-medium text-gray-700">Temperature fields</span>
      <div>
        <%= f.fields_for :temperature do |temperature_fields| %>
          <%= temperature_fields.label :degrees, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 space-y-2">
            <%= temperature_fields.range_field :scale,
                min: 0,
                max: 100,
                step: 1,
                class: "w-full" %>
  
          </div>
        <% end %>
      </div>

      <div>
        <%= f.label :consumption_time, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= f.datetime_field :consumed_at, class: "block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>

      <div class="flex justify-end">
        <button type="submit" class="flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          Next
        </button>
      </div>

      <% if @beverage_log.errors.any? %>
        <p class="mt-2 text-sm text-red-600">
          <%= @beverage_log.errors.full_messages.join(", ") %>
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>