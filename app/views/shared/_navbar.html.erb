<nav class="bg-white shadow-sm " data-controller="navbar">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between">
      <div class="flex">
        <div class="flex flex-shrink-0 items-center">
          <%= link_to root_path, class: "text-xl font-bold text-blue-600" do %>
            💧 Hydration Tracker
          <% end %>
        </div>
        <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", root_path, 
                class: "inline-flex items-center border-b-2 #{current_page?(root_path) ? 'border-blue-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} px-1 pt-1 text-sm font-medium" %>
            <%= link_to "New Log", new_tracking_beverage_log_path,
                class: "inline-flex items-center border-b-2 #{current_page?(new_tracking_beverage_log_path) ? 'border-blue-500 text-gray-900' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} px-1 pt-1 text-sm font-medium" %>
          <% end %>
        </div>
      </div>
      <div class="hidden sm:ml-6 sm:flex sm:items-center">
        <% if user_signed_in? %>
          <div class="relative ml-3" data-controller="dropdown">
            <div>
              <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="flex rounded-full bg-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" id="user-menu-button" aria-expanded="false" aria-haspopup="true">
                <span class="sr-only">Open user menu</span>
                <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center">
                  <span class="text-blue-700"><%= current_user.email.first.upcase %></span>
                </div>
              </button>
            </div>
            <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button" tabindex="-1">
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
            </div>
          </div>
        <% else %>
          <%= link_to "Sign in", new_user_session_path, class: "text-gray-500 hover:text-gray-700 text-sm font-medium" %>
          <%= link_to "Sign up", new_user_registration_path, class: "ml-4 inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" %>
        <% end %>
      </div>
      <div class="-mr-2 flex items-center sm:hidden">
        <button type="button" data-action="navbar#toggleMenu" class="inline-flex items-center justify-center rounded-md p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="sm:hidden hidden" id="mobile-menu" data-navbar-target="menu">
    <div class="space-y-1 pb-3 pt-2">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", root_path, 
            class: "block border-l-4 #{current_page?(root_path) ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-transparent text-gray-500 hover:border-gray-300 hover:bg-gray-50 hover:text-gray-700'} py-2 pl-3 pr-4 text-base font-medium" %>
        <%= link_to "New Log", new_tracking_beverage_log_path,
            class: "block border-l-4 #{current_page?(new_tracking_beverage_log_path) ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-transparent text-gray-500 hover:border-gray-300 hover:bg-gray-50 hover:text-gray-700'} py-2 pl-3 pr-4 text-base font-medium" %>
      <% end %>
    </div>
    <div class="border-t border-gray-200 pb-3 pt-4">
      <% if user_signed_in? %>
        <div class="flex items-center px-4">
          <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center">
            <span class="text-blue-700"><%= current_user.email.first.upcase %></span>
          </div>
          <div class="ml-3">
            <div class="text-base font-medium text-gray-800"><%= current_user.email %></div>
          </div>
        </div>
        <div class="mt-3 space-y-1">
          <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              class: "block w-full text-left px-4 py-2 text-base font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-800" %>
        </div>
      <% else %>
        <div class="mt-3 space-y-1 px-2">
          <%= link_to "Sign in", new_user_session_path,
              class: "block rounded-md px-3 py-2 text-base font-medium text-gray-500 hover:bg-gray-50 hover:text-gray-800" %>
          <%= link_to "Sign up", new_user_registration_path,
              class: "block rounded-md px-3 py-2 text-base font-medium text-gray-500 hover:bg-gray-50 hover:text-gray-800" %>
        </div>
      <% end %>
    </div>
  </div>
</nav> 